# Nyaya Sahayak — Environment Variables
# Copy this file and fill in your keys

# Sarvam AI — used for LLM (sarvam-m), voice (TTS/STT), and translation
SARVAM_API_KEY=sk_z9wlshp0_hNDLkngJ3UkWu56GSe4CeDjV

# LLM endpoint (Sarvam AI is OpenAI-compatible)
LLM_OPENAI_BASE_URL=https://api.sarvam.ai/v1
LLM_MODEL=sarvam-m
LLM_TEMPERATURE=0.2

# FAISS index paths (update if running locally)
FAISS_INDEX_DIR=/Volumes/workspace/default/bharat_bricks_hacks/nyaya_index
PARENT_STORE_DIR=/Volumes/workspace/default/bharat_bricks_hacks/nyaya_index

# Unity Catalog
NYAYA_CATALOG=workspace
NYAYA_SCHEMA=default
